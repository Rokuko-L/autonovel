# Anthropic API key (required — also used by DeepSeek Anthropic Compatibility Layer)
# ANTHROPIC_API_KEY=sk-ant-...

# API base URL (default: https://api.anthropic.com)
# For DeepSeek: https://api.deepseek.com/anthropic
# Legacy fallback: AUTONOVEL_API_BASE_URL (if ANTHROPIC_BASE_URL is empty)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# DeepSeek Anthropic Compatibility Layer example (uncomment and fill in):
ANTHROPIC_API_KEY=sk-deepseek-your-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Writer model (used for drafting and revision)
# DeepSeek: deepseek-v4-flash
AUTONOVEL_WRITER_MODEL=deepseek-v4-flash

# Judge model (used for evaluation, comparisons, adversarial editing — should differ from writer)
# DeepSeek: deepseek-v4-pro
AUTONOVEL_JUDGE_MODEL=deepseek-v4-pro

# Review model (Opus — deep prose-level analysis, used in Phase 3b)
# DeepSeek: deepseek-v4-pro
AUTONOVEL_REVIEW_MODEL=deepseek-v4-pro
